<div class="page-header">
  <div>
    <h1 class="page-title">Clientes</h1>
    <p class="page-subtitle">Tomadores cadastrados no tenant atual.</p>
  </div>
</div>

<div class="panel table-wrap">
  <table>
    <thead>
      <tr>
        <th>Nome</th>
        <th>Documento</th>
        <th>Email</th>
        <th>Cidade</th>
        <th>Criado em</th>
      </tr>
    </thead>
    <tbody>
      <% @customers.each do |customer| %>
        <tr>
          <td><%= customer.legal_name %></td>
          <td><span class="mono"><%= customer.document_type %>:<%= customer.document_number %></span></td>
          <td><%= customer.email.presence || "-" %></td>
          <td><%= customer.city_code %></td>
          <td><%= local_time(customer.created_at) %></td>
        </tr>
      <% end %>

      <% if @customers.empty? %>
        <tr>
          <td colspan="5" class="muted">Nenhum cliente cadastrado.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
